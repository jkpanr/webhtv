<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:background="@drawable/selector_player_osd_row"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="14dp">

    <View
        android:id="@+id/mark"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:background="@drawable/selector_player_osd_mark"
        android:duplicateParentState="true" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_weight="1"
        android:duplicateParentState="true"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="@color/player_osd_item_text"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:text="Playback params" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/state"
        android:layout_width="56dp"
        android:layout_height="30dp"
        android:layout_marginStart="14dp"
        android:background="@drawable/selector_player_osd_state"
        android:duplicateParentState="true"
        android:gravity="center"
        android:includeFontPadding="false"
        android:singleLine="true"
        android:textColor="@color/player_osd_state_text"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="On" />

</androidx.appcompat.widget.LinearLayoutCompat>
